<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="BackgroundDark">#121212</Color>
    <Color x:Key="SurfaceDark">#1E1E1E</Color>
    <Color x:Key="BackgroundLight">#F5F5F5</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>

    <Color x:Key="PrimaryAccent">#00D4FF</Color>
    <Color x:Key="SecondaryAccent">#FFD700</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B0B0B0</Color>
    <Color x:Key="TextTertiary">#757575</Color>
    <Color x:Key="TextPrimaryLight">#212121</Color>
    <Color x:Key="TextSecondaryLight">#757575</Color>

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- ===================== MOKO / Neo-Retro tokens ===================== -->
    <!-- Superficies y trazos (alfa en #AARRGGBB) -->
    <Color x:Key="Stage">#FF07060F</Color>
    <Color x:Key="MokoBg1">#FF170F33</Color>
    <Color x:Key="MokoBg2">#FF1B1240</Color>
    <Color x:Key="MokoBg3">#FF241650</Color>
    <Color x:Key="Glass">#0DFFFFFF</Color>
    <Color x:Key="Glass2">#16FFFFFF</Color>
    <Color x:Key="StrokeSoft">#10FFFFFF</Color>
    <Color x:Key="StrokeHard">#1AFFFFFF</Color>

    <!-- Tinta -->
    <Color x:Key="Ink">#FFFFFFFF</Color>
    <Color x:Key="Ink2">#FFC9C2EA</Color>
    <Color x:Key="Ink3">#FF8B84AD</Color>
    <Color x:Key="Ink4">#FF615A82</Color>

    <!-- Acento + oro -->
    <Color x:Key="AccentPink">#FFFF5F8F</Color>
    <Color x:Key="AccentPink2">#FFFF4F7E</Color>
    <Color x:Key="AccentInk">#FF2A0A16</Color>
    <Color x:Key="AccentGlow">#6BFF5F8F</Color>
    <Color x:Key="Gold">#FFF7C948</Color>
    <Color x:Key="GoldSoft">#24F7C948</Color>

    <!-- Estados (semáforo / vitales) -->
    <Color x:Key="StOk">#FF3DDC97</Color>
    <Color x:Key="StOkSoft">#263DDC97</Color>
    <Color x:Key="StWork">#FFFFAC4D</Color>
    <Color x:Key="StWorkSoft">#29FFAC4D</Color>
    <Color x:Key="StBusy">#FFFF5C6C</Color>
    <Color x:Key="StBusySoft">#29FF5C6C</Color>
    <Color x:Key="StCrystal">#FF86B4FF</Color>
    <Color x:Key="StCrystalSoft">#2986B4FF</Color>
    <Color x:Key="Hunger">#FFFF6A5C</Color>

    <!-- Brushes -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFF77A6" Offset="0.0"/>
        <GradientStop Color="#FFFF4F7E" Offset="1.0"/>
    </LinearGradientBrush>
    <!-- Fondo de app: glow superior radial → oscuro (mata lo plano) -->
    <RadialGradientBrush x:Key="AppBgBrush" Center="0.5,0.08" Radius="1.15">
        <GradientStop Color="#FF1E0E45" Offset="0.0"/>
        <GradientStop Color="#FF130829" Offset="0.5"/>
        <GradientStop Color="#FF070314" Offset="1.0"/>
    </RadialGradientBrush>
    <!-- Tarjeta "glass" con luz: ligeramente más clara arriba -->
    <LinearGradientBrush x:Key="CardGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#18FFFFFF" Offset="0.0"/>
        <GradientStop Color="#09FFFFFF" Offset="1.0"/>
    </LinearGradientBrush>
    <!-- Blobs de luz ambiental (para MokoBackground) -->
    <RadialGradientBrush x:Key="GlowPurpleBrush" Center="0.5,0.5" Radius="0.5">
        <GradientStop Color="#322C1A66" Offset="0.0"/>
        <GradientStop Color="#002C1A66" Offset="1.0"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="GlowMagentaBrush" Center="0.5,0.5" Radius="0.5">
        <GradientStop Color="#26401E70" Offset="0.0"/>
        <GradientStop Color="#00401E70" Offset="1.0"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="GlowAccentBrush" Center="0.5,0.5" Radius="0.5">
        <GradientStop Color="#2EFF5F8F" Offset="0.0"/>
        <GradientStop Color="#00FF5F8F" Offset="1.0"/>
    </RadialGradientBrush>
    <!-- Viñeta: bordes oscuros para dar profundidad -->
    <RadialGradientBrush x:Key="VignetteBrush" Center="0.5,0.4" Radius="0.72">
        <GradientStop Color="#00000000" Offset="0.45"/>
        <GradientStop Color="#7A000000" Offset="1.0"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDark}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}"/>
</ResourceDictionary>