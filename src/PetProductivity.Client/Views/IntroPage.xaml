<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             xmlns:vm="clr-namespace:PetProductivity.Client.ViewModels"
             x:Class="PetProductivity.Client.Views.IntroPage"
             Shell.NavBarIsVisible="False"
             Background="{StaticResource AppBgBrush}">

    <ContentPage.BindingContext>
        <vm:IntroViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*, Auto, Auto, *" Padding="30">

        <!-- Hero -->
        <VerticalStackLayout Grid.Row="1" Spacing="12" VerticalOptions="Center">
            <Label Text="{loc:T '🥚'}" FontSize="100" HorizontalOptions="Center"
                   Shadow="{Shadow Brush={StaticResource Gold}, Offset='0,0', Radius=40, Opacity=0.7}"/>
            <Label Text="Moko" Style="{StaticResource DisplayXL}" FontSize="40" HorizontalTextAlignment="Center" HorizontalOptions="Center"/>
            <Label Text="{loc:T 'Gamifica tu productividad'}" Style="{StaticResource Caption}" FontSize="16" HorizontalTextAlignment="Center" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Acción -->
        <VerticalStackLayout Grid.Row="2" Spacing="16" Margin="0,60,0,0">
            <Button Text="{loc:T 'Comenzar aventura'}" Command="{Binding NavigateToDashboardCommand}"
                    Style="{StaticResource BtnAccent}" FontSize="18" HeightRequest="58"
                    Shadow="{Shadow Brush={StaticResource AccentPink}, Radius=18, Opacity=0.45}"/>
            <Label Text="{loc:T 'Potenciado por IA en la nube'}" Style="{StaticResource Caption}" TextColor="{StaticResource Ink4}" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
