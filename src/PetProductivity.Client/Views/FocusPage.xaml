<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             xmlns:views="clr-namespace:PetProductivity.Client.Views"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:ctrl="clr-namespace:PetProductivity.Client.Controls"
             x:Class="PetProductivity.Client.Views.FocusPage"
             Shell.NavBarIsVisible="False"
             Background="{StaticResource AppBgBrush}">

    <Grid>
        <views:MokoBackground />
        <ScrollView>
            <VerticalStackLayout Padding="22,18,22,28" Spacing="18">

                <ctrl:BackButton />

                <!-- Tema (la tarea a enfocar) -->
                <Label Text="{Binding Description}" Style="{StaticResource DisplayTitle}" FontSize="20"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <!-- Mascota en un círculo + anillo-temporizador alrededor -->
                <Grid WidthRequest="260" HeightRequest="260" HorizontalOptions="Center">
                    <skia:SKCanvasView x:Name="RingCanvas" PaintSurface="OnPaintRing"/>
                    <Border WidthRequest="188" HeightRequest="188" StrokeThickness="0"
                            BackgroundColor="{StaticResource Glass2}" HorizontalOptions="Center" VerticalOptions="Center"
                            StrokeShape="RoundRectangle 94">
                        <Image x:Name="PetImage"
                               Source="{Binding PetImageSource, FallbackValue='pet_egg.png', TargetNullValue='pet_egg.png'}"
                               Aspect="AspectFit" WidthRequest="138" HeightRequest="138"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Cuenta atrás (solo en foco activo) -->
                <Label Text="{Binding FocusRemaining}" IsVisible="{Binding IsFocusMode}" Style="{StaticResource DisplayXL}"
                       FontSize="46" HorizontalOptions="Center" TextColor="{StaticResource AccentPink}"/>
                <Label Text="{Binding StatusMessage}" TextColor="{StaticResource Ink2}" FontAttributes="Italic"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <!-- Comprobante en revisión (Gemini Vision juzgando la foto) -->
                <HorizontalStackLayout IsVisible="{Binding IsCheckingProof}" Spacing="8" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsCheckingProof}" Color="{StaticResource AccentPink}" WidthRequest="18" HeightRequest="18"/>
                    <Label Text="{loc:T 'Comprobante en revisión…'}" TextColor="{StaticResource Ink2}" FontAttributes="Italic" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Config (sin foco activo): elegir duración + comenzar -->
                <VerticalStackLayout IsVisible="{Binding IsNotFocusMode}" Spacing="12">
                    <Border Style="{StaticResource Card}" Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{loc:T 'Duración del foco'}" TextColor="{StaticResource Ink}" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding FocusMinutesLabel}" TextColor="{StaticResource AccentPink}"
                                       FontAttributes="Bold" FontSize="16" VerticalOptions="Center"/>
                            </Grid>
                            <Slider Minimum="5" Maximum="120" Value="{Binding FocusMinutes}"/>
                            <Label Text="{Binding AllowedAppsSummary}" Style="{StaticResource Caption}" TextColor="{StaticResource Ink4}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Meta diaria de foco -->
                    <Border Style="{StaticResource Card}" Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding DailyGoalLabel}" TextColor="{StaticResource Ink}" FontSize="13.5"/>
                            <ctrl:RoundedBar Progress="{Binding DailyGoalProgress}" Fill="{StaticResource AccentPink}"
                                             Track="{StaticResource Glass2}" BarHeight="8"/>
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="{loc:T 'Comenzar foco'}" Command="{Binding StartFocusCommand}"
                            Style="{StaticResource BtnAccent}" HeightRequest="56"/>
                </VerticalStackLayout>

                <!-- Foco activo: cancelar (con confirmación + incentivo) -->
                <VerticalStackLayout IsVisible="{Binding IsFocusMode}" Spacing="4" HorizontalOptions="Fill">
                    <Label Text="{loc:T 'Quédate en PetProductivity o en tus apps permitidas.'}"
                           Style="{StaticResource Caption}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Button Text="{loc:T 'Cancelar foco (sin recompensa)'}" Command="{Binding CancelFocusCommand}"
                            Style="{StaticResource BtnGhost}" HeightRequest="50"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
