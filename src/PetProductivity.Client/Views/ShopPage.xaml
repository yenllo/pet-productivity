<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             xmlns:vm="clr-namespace:PetProductivity.Client.ViewModels"
             xmlns:views="clr-namespace:PetProductivity.Client.Views"
             xmlns:ctrl="clr-namespace:PetProductivity.Client.Controls"
             x:Class="PetProductivity.Client.Views.ShopPage"
             Shell.NavBarIsVisible="False"
             Title="{loc:T 'Tienda'}"
             Background="{StaticResource AppBgBrush}">

    <Grid>
    <views:MokoBackground />
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="20,50,20,0">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <VerticalStackLayout>
                <Label Text="{loc:T 'Mercader'}" Style="{StaticResource Eyebrow}" />
                <Label Text="{loc:T 'Tienda'}" Style="{StaticResource DisplayTitle}" />
            </VerticalStackLayout>
            <Border Grid.Column="1" Style="{StaticResource Chip}" BackgroundColor="{StaticResource GoldSoft}"
                    Stroke="{StaticResource Gold}" VerticalOptions="Center">
                <!-- T31: tap = para qué sirve el oro y qué significa el amarillo -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ExplainCommand}" CommandParameter="oro"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <Image Source="spr_coin.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                    <Label Text="{Binding UserGold}" TextColor="{StaticResource Gold}" FontAttributes="Bold"
                           FontSize="14" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- Buscador -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 14" BackgroundColor="{StaticResource Glass2}"
                Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" Margin="0,14,0,0" Padding="6,0">
            <SearchBar Text="{Binding SearchText}" Placeholder="{loc:T 'Buscar objetos…'}"
                       BackgroundColor="Transparent" TextColor="{StaticResource Ink}"
                       PlaceholderColor="{StaticResource Ink3}" CancelButtonColor="{StaticResource AccentPink}" />
        </Border>

        <!-- Category chips (cableados al VM: filtran el catálogo). #22: chevron fijo = pista de scroll horizontal. -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,4">
        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Categories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 16" BackgroundColor="{StaticResource Glass2}"
                                Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" Padding="15,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShopViewModel}}, Path=SelectCategoryCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <!-- T27: seleccionado = borde/texto acento, SIN relleno solido (mismo fondo translucido que el resto). -->
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource AccentPink}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding DisplayName}" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource Ink3}" VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource AccentPink}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>
        <Label Grid.Column="1" Text="{loc:T '›'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Ink3}"
               VerticalOptions="Center" Margin="4,0,0,0" />
        </Grid>

        <!-- VISTA COMPACTA: rejilla 3xN de solo imagen + precio (muebles). Fondo amarillo si alcanza el oro. -->
        <CollectionView Grid.Row="3" ItemsSource="{Binding Items}" Margin="0,8,0,0" IsVisible="{Binding IsCompactView}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="10" HorizontalItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 14" BackgroundColor="{StaticResource Glass2}"
                            Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" Padding="6" HeightRequest="130">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Affordable}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Gold}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShopViewModel}}, Path=ActCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="2">
                            <Label Grid.Row="0" Text="{Binding Name}" FontSize="9.5" MaxLines="2"
                                   LineBreakMode="TailTruncation" HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource Ink3}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Affordable}" Value="True">
                                        <Setter Property="TextColor" Value="#2A1D00" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Image Grid.Row="1" Source="{Binding SpriteImageSource}" IsVisible="{Binding HasSprite}"
                                   Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                            <Label Grid.Row="1" Text="{Binding Emoji}" IsVisible="{Binding NoSprite}" FontSize="30"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Row="2" Spacing="3" HorizontalOptions="Center">
                                <Image Source="spr_coin.png" HeightRequest="13" WidthRequest="13" VerticalOptions="Center" />
                                <Label Text="{Binding CompactPrice}" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink2}" VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Affordable}" Value="True">
                                            <Setter Property="TextColor" Value="#2A1D00" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- VISTA DETALLADA: tarjetas 2x2 con info (consumibles / cosmético / estilos / premium / eventos). -->
        <CollectionView Grid.Row="3" ItemsSource="{Binding Items}" Margin="0,8,0,0" IsVisible="{Binding IsDetailedView}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="12" HorizontalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="13">
                        <VerticalStackLayout Spacing="6">
                            <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource Glass2}"
                                    Stroke="{StaticResource StrokeSoft}" StrokeThickness="1"
                                    HeightRequest="54" WidthRequest="54" HorizontalOptions="Start">
                                <Grid>
                                    <Image Source="{Binding SpriteImageSource}" IsVisible="{Binding HasSprite}"
                                           HeightRequest="44" WidthRequest="44" Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Label Text="{Binding Emoji}" IsVisible="{Binding NoSprite}" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                            <Label Text="{Binding Name}" Style="{StaticResource DisplayTitle}" FontSize="14.5" />
                            <Border IsVisible="{Binding ShowRarity}" StrokeShape="RoundRectangle 8" Padding="7,2"
                                    BackgroundColor="{StaticResource Glass2}" Stroke="{StaticResource StrokeSoft}"
                                    StrokeThickness="1" HorizontalOptions="Start">
                                <Label Text="{Binding RarityLabel}" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource Gold}" />
                            </Border>
                            <Label Text="{Binding Description}" Style="{StaticResource Caption}" />
                            <Label Text="{Binding CountdownLabel}" IsVisible="{Binding ShowCountdown}" FontSize="11"
                                   FontAttributes="Bold" TextColor="{StaticResource AccentPink}" />
                            <Label Text="{Binding SourceLabel}" IsVisible="{Binding ShowSource}" FontSize="10"
                                   TextColor="{StaticResource Ink3}" />
                            <Button Text="{Binding PriceLabel}"
                                    ImageSource="spr_coin.png" ContentLayout="Left,6"
                                    IsEnabled="{Binding CanAct}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShopViewModel}}, Path=ActCommand}"
                                    CommandParameter="{Binding .}"
                                    Style="{StaticResource BtnGhost}" HeightRequest="38" FontSize="13" Margin="0,6,0,0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding Affordable}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Gold}" />
                                        <Setter Property="TextColor" Value="#2A1D00" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Estados: cargando / vacío / error -->
        <ActivityIndicator Grid.Row="3" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                           Color="{StaticResource AccentPink}" VerticalOptions="Center" HorizontalOptions="Center" />
        <Label Grid.Row="3" Text="{Binding StatusMessage}" IsVisible="{Binding ShowStatus}"
               Style="{StaticResource Caption}" VerticalOptions="Center" HorizontalOptions="Center"
               HorizontalTextAlignment="Center" Margin="40,0" />

        <!-- Paginación (solo si hay más de una página) -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Padding="0,6,0,10" IsVisible="{Binding HasPages}">
            <Button Grid.Column="0" Text="{loc:T '‹ Anterior'}" Command="{Binding PrevPageCommand}" IsEnabled="{Binding CanPrev}"
                    Style="{StaticResource BtnGhost}" HeightRequest="40" FontSize="13" />
            <Label Grid.Column="1" Text="{Binding PageInfo}" Style="{StaticResource Caption}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="{loc:T 'Siguiente ›'}" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanNext}"
                    Style="{StaticResource BtnGhost}" HeightRequest="40" FontSize="13" />
        </Grid>
    </Grid>

    <!-- T31: overlay explicativo (tap en el chip de oro; también 1ª visita, Lote 3) -->
    <ctrl:InfoOverlay ZIndex="113" IsOpen="{Binding ShowInfo}"
                      HeaderText="{Binding InfoTitle}" Body="{Binding InfoBody}"/>
    </Grid>
</ContentPage>
