<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             x:Class="PetProductivity.Client.Views.BirthCeremonyPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Stage}">

    <Grid>
        <!-- Egg GIF (animación nativa, controlada desde el code-behind) -->
        <Image x:Name="EggImage" Source="egg_crack.gif" IsAnimationPlaying="True" Aspect="AspectFit"
               HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="250" HeightRequest="250" />

        <!-- Criatura revelada -->
        <Image x:Name="CreatureImage" Source="{Binding RevealedSpeciesImage}" Aspect="AspectFit" Opacity="0"
               HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="250" HeightRequest="250" />

        <!-- Nombrado -->
        <StackLayout x:Name="InputContainer" Opacity="0" VerticalOptions="End" Margin="0,0,0,100"
                     HorizontalOptions="Center" WidthRequest="300" Spacing="18">

            <Label Text="{loc:T '¿Cómo se llamará tu mascota?'}" TextColor="{StaticResource Ink}" HorizontalOptions="Center" FontSize="18" />

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource Glass2}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" Padding="14,2">
                <Entry Text="{Binding PetName}" Placeholder="{loc:T 'Nombre de la mascota'}" MaxLength="24" BackgroundColor="Transparent"
                       TextColor="{StaticResource Ink}" PlaceholderColor="{StaticResource Ink4}" HorizontalTextAlignment="Center" HeightRequest="48" />
            </Border>

            <Button Text="{loc:T 'Comenzar'}" Command="{Binding StartJourneyCommand}" Style="{StaticResource BtnAccent}" />

            <Label Text="{loc:T '¿Ya tienes cuenta? Inicia Sesión'}" TextColor="{StaticResource Ink3}" HorizontalOptions="Center"
                   TextDecorations="Underline" FontSize="14" Margin="0,10,0,0">
                <Label.GestureRecognizers><TapGestureRecognizer Command="{Binding NavigateToLoginCommand}"/></Label.GestureRecognizers>
            </Label>
        </StackLayout>

        <!-- Flash blanco -->
        <BoxView x:Name="FlashOverlay" Color="White" Opacity="0" InputTransparent="True" />
    </Grid>
</ContentPage>
