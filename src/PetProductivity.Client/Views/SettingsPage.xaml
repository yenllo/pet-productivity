<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             xmlns:vm="clr-namespace:PetProductivity.Client.ViewModels"
             xmlns:views="clr-namespace:PetProductivity.Client.Views"
             x:Class="PetProductivity.Client.Views.SettingsPage"
             Title="{loc:T 'Configuración'}"
             Shell.NavBarIsVisible="False"
             Background="{StaticResource AppBgBrush}">

    <Grid>
    <views:MokoBackground />
    <ScrollView>
        <VerticalStackLayout Padding="20,50,20,40" Spacing="6">

            <!-- Header -->
            <Label Text="{loc:T 'Preferencias'}" Style="{StaticResource Eyebrow}" />
            <Label Text="{loc:T 'Ajustes'}" Style="{StaticResource DisplayTitle}" Margin="0,0,0,10" />

            <!-- T27-L2 (#28): la sección "Servidor" ya no vive arriba; se movió al menú "Desarrollador" (abajo). -->

            <!-- APARIENCIA -->
            <Label Text="{loc:T 'Apariencia'}" Style="{StaticResource SectionLabel}" Margin="2,18,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Label Text="{loc:T 'Modo oscuro'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding IsDarkTheme}" Style="{StaticResource MokoSwitch}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <!-- T27-L3 (#26): tocar cicla Sistema → Español → English -->
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CycleLanguageCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Text="{loc:T 'Idioma'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding LanguageLabel}" TextColor="{StaticResource AccentPink}"
                               FontSize="14.5" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- NOTIFICACIONES -->
            <Label Text="{loc:T 'Notificaciones'}" Style="{StaticResource SectionLabel}" Margin="2,18,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Label Text="{loc:T 'Activar notificaciones'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding NotificationsEnabled}" Style="{StaticResource MokoSwitch}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <!-- placeholder: aún sin binding en el VM -->
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Label Text="{loc:T 'Recordar el ritual diario'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding RemindDailyRitual}" Style="{StaticResource MokoSwitch}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- MODO FOCO -->
            <VerticalStackLayout IsVisible="{Binding FocusSupported}" Spacing="6">
                <Label Text="{loc:T 'Modo foco'}" Style="{StaticResource SectionLabel}" Margin="2,18,0,8" />
                <Border Style="{StaticResource Card}" Padding="0">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{loc:T 'Acceso de uso'}" TextColor="{StaticResource Ink}" FontSize="14.5" />
                                <Label Text="{Binding UsageStatus}" TextColor="{Binding UsageColor}" FontSize="12.5" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="{loc:T 'Conceder'}" Command="{Binding GrantUsageAccessCommand}"
                                    Style="{StaticResource BtnGhost}" HeightRequest="38" FontSize="13" Padding="16,0" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                        <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{loc:T 'Mostrar sobre otras apps'}" TextColor="{StaticResource Ink}" FontSize="14.5" />
                                <Label Text="{Binding OverlayStatus}" TextColor="{Binding OverlayColor}" FontSize="12.5" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="{loc:T 'Conceder'}" Command="{Binding GrantOverlayCommand}"
                                    Style="{StaticResource BtnGhost}" HeightRequest="38" FontSize="13" Padding="16,0" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                        <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{loc:T 'Notificaciones'}" TextColor="{StaticResource Ink}" FontSize="14.5" />
                                <Label Text="{Binding NotifStatus}" TextColor="{Binding NotifColor}" FontSize="12.5" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="{loc:T 'Conceder'}" Command="{Binding GrantNotificationsCommand}"
                                    Style="{StaticResource BtnGhost}" HeightRequest="38" FontSize="13" Padding="16,0" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                        <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{loc:T 'Apps permitidas'}" TextColor="{StaticResource Ink}" FontSize="14.5" />
                                <Label Text="{Binding FocusAppsSummary}" TextColor="{StaticResource Ink3}" FontSize="12.5" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="{loc:T 'Elegir'}" Command="{Binding OpenFocusAppsCommand}"
                                    Style="{StaticResource BtnGhost}" HeightRequest="38" FontSize="13" Padding="16,0" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                        <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                            <Label Text="{loc:T 'Meta diaria (min)'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Text="{Binding FocusGoalMinutes}" Keyboard="Numeric"
                                   WidthRequest="70" HorizontalTextAlignment="End"
                                   TextColor="{StaticResource Ink}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                        <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{loc:T 'Recompensas por foto'}" TextColor="{StaticResource Ink}" FontSize="14.5" />
                                <Label Text="{loc:T 'Pide una foto a mitad del foco; verificada da 2× la recompensa. Opcional.'}"
                                       TextColor="{StaticResource Ink3}" FontSize="12.5" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding PhotoRewardsEnabled}" Style="{StaticResource MokoSwitch}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Label Text="{loc:T 'Durante el foco solo podrás usar PetProductivity y las apps permitidas (máx 3).'}"
                       Style="{StaticResource Caption}" TextColor="{StaticResource Ink4}" Margin="6,8,0,0" />
            </VerticalStackLayout>

            <!-- ACERCA DE -->
            <Label Text="{loc:T 'Acerca de'}" Style="{StaticResource SectionLabel}" Margin="2,18,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Label Text="{loc:T 'Versión'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{loc:T '1.0'}" TextColor="{StaticResource Ink3}" FontSize="13" VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding OpenCreditsCommand}"/></Grid.GestureRecognizers>
                        <Label Text="{loc:T 'Créditos'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{loc:T '›'}" TextColor="{StaticResource Ink4}" FontSize="18" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- CUENTA (T14-C1): privacidad + borrado (requisito de Google Play) -->
            <Label Text="{loc:T 'Cuenta'}" Style="{StaticResource SectionLabel}" Margin="2,18,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding OpenPrivacyPolicyCommand}"/></Grid.GestureRecognizers>
                        <Label Text="{loc:T 'Política de privacidad'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{loc:T '›'}" TextColor="{StaticResource Ink4}" FontSize="18" VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding DeleteAccountCommand}"/></Grid.GestureRecognizers>
                        <Label Text="{loc:T 'Borrar cuenta'}" TextColor="#E05B5B" FontSize="14.5" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{loc:T '›'}" TextColor="{StaticResource Ink4}" FontSize="18" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- DESARROLLADOR (T27-L2 #28): la config de servidor/IA vive aquí ahora, colapsada -->
            <Label Text="{loc:T 'Desarrollador'}" Style="{StaticResource SectionLabel}" Margin="2,18,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                    <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleDeveloperCommand}"/></Grid.GestureRecognizers>
                    <Label Text="{loc:T 'Opciones de desarrollador'}" TextColor="{StaticResource Ink}" FontSize="14.5" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{loc:T '›'}" TextColor="{StaticResource Ink4}" FontSize="18" VerticalOptions="Center" />
                </Grid>
            </Border>
            <Border Style="{StaticResource Card}" Padding="0" IsVisible="{Binding ShowDeveloper}" Margin="0,6,0,0">
                <VerticalStackLayout>
                    <VerticalStackLayout Padding="15,12" Spacing="4">
                        <Label Text="{loc:T 'URL del servidor'}" TextColor="{StaticResource Ink}" FontSize="14.5" />
                        <Entry Text="{Binding ServerUrl}" Placeholder="https://petproductivity.onrender.com"
                               TextColor="{StaticResource Ink2}" PlaceholderColor="{StaticResource Ink4}" FontSize="13" />
                    </VerticalStackLayout>
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="15,12">
                        <Label Text="{Binding ConnectionStatus}" TextColor="{Binding ConnectionStatusColor}"
                               FontAttributes="Bold" FontSize="13" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="{loc:T 'Probar ping'}" Command="{Binding TestConnectionCommand}"
                                Style="{StaticResource BtnGhost}" HeightRequest="38" FontSize="13" Padding="16,0" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <Label Text="{loc:T 'Cambiar estos valores requiere reiniciar la app.'}" Style="{StaticResource Caption}"
                           TextColor="{StaticResource Ink4}" Padding="15,10" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
    </Grid>
</ContentPage>
