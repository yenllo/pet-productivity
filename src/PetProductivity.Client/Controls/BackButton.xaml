<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             x:Class="PetProductivity.Client.Controls.BackButton">
    <!-- Back in-page (estilo RegisterPage): reemplaza la flecha nativa de la barra Shell. -->
    <Button Text="{loc:T '‹ Atrás'}" Clicked="OnClicked" BackgroundColor="Transparent"
            TextColor="{StaticResource Ink3}" FontSize="15" Padding="0"
            HorizontalOptions="Start" BorderWidth="0"/>
</ContentView>
