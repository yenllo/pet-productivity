<?xml version="1.0" encoding="utf-8" ?>
<!-- T31: mini-overlay explicativo reutilizable (plantilla = selector de estado del Dashboard).
     Uso: <ctrl:InfoOverlay IsOpen="{Binding ShowInfo}" HeaderText="{Binding InfoTitle}" Body="{Binding InfoBody}"/> -->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:PetProductivity.Client.Services"
             x:Class="PetProductivity.Client.Controls.InfoOverlay"
             IsVisible="False">
    <!-- El velo va en el BackgroundColor del Grid (patrón TaskPage): un BoxView translúcido
         pinta sobre una base gris opaca en Android y tapa la página. -->
    <Grid BackgroundColor="{StaticResource Scrim}">
        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnDismiss"/></Grid.GestureRecognizers>
        <Border x:Name="Card" Style="{StaticResource Card}" Stroke="#59FF5F8F" StrokeThickness="2"
                VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="300" Padding="18">
            <VerticalStackLayout Spacing="12">
                <Label x:Name="TitleLabel" Style="{StaticResource DisplayTitle}" FontSize="18" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Label x:Name="BodyLabel" TextColor="{DynamicResource Ink2}" FontSize="14"
                       LineBreakMode="WordWrap" HorizontalTextAlignment="Center"/>
                <Button Text="{loc:T 'Entendido'}" Clicked="OnDismiss" Style="{StaticResource BtnAccent}" HeightRequest="46" Margin="0,4,0,0"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
